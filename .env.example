# memspine environment — copy to .env and fill in. Never commit .env.
# Config precedence: defaults -> template -> user YAML -> env (this file) -> runtime kwargs (D-11)

# --- Behavior ---
# Hard-fail when a required service is missing (D-10). Set false for a dev escape hatch.
MEMSPINE_STRICT_SERVICES=true

# --- LLM (local / open-weight first; D-07/D-39) ---
# Any OpenAI-compatible endpoint works: Ollama, vLLM, LM Studio, llama.cpp server.
MEMSPINE_LLM_BASE_URL=http://localhost:11434/v1
MEMSPINE_LLM_API_KEY=ollama
MEMSPINE_LLM_MODEL_EXTRACT=qwen2.5:7b
MEMSPINE_LLM_MODEL_JUDGE=qwen2.5:3b
MEMSPINE_LLM_MODEL_CHAT=qwen2.5:7b

# --- Embeddings (fastembed/ONNX default; D-08) ---
MEMSPINE_EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Stores (defaults are embedded/offline) ---
MEMSPINE_SQLITE_PATH=./.memspine/memspine.db
MEMSPINE_LANCE_PATH=./.memspine/lance
MEMSPINE_GRAPH_PATH=./.memspine/graph
MEMSPINE_LMDB_PATH=./.memspine/cache

# --- Optional: AWS (Bedrock LLM/embeddings + Secrets Manager; [aws]) ---
# AWS_REGION=us-east-1
# MEMSPINE_SECRETS_BACKEND=aws   # default: env

# --- Optional: production swap-ins ---
# MEMSPINE_POSTGRES_URL=postgresql+psycopg://user:pass@localhost/memspine
# MEMSPINE_VALKEY_URL=valkey://localhost:6379
